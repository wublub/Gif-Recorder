<Window x:Class="GifRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GIF 录制工具"
        Width="760"
        Height="560"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="Window_SourceInitialized"
        Closed="Window_Closed">
    <DockPanel Margin="20" LastChildFill="True">
        <!--
          底部操作栏固定在窗口底部，避免提示文字/状态区域遮挡按钮导致点不了。
        -->
        <WrapPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" Panel.ZIndex="100">
            <Button x:Name="StartButton" Width="120" Height="38" Margin="0,0,10,10" Click="StartButton_OnClick">开始录制</Button>
            <Button x:Name="StopButton" Width="160" Height="38" Margin="0,0,10,10" IsEnabled="False" Click="StopButton_OnClick">停止录制</Button>
            <Button x:Name="ExportButton" Width="140" Height="38" Margin="0,0,10,10" IsEnabled="False" Click="ExportButton_OnClick">导出当前素材</Button>
            <Button x:Name="TrimButton" Width="120" Height="38" Margin="0,0,10,10" IsEnabled="False" Click="OpenTrimButton_OnClick">打开裁剪</Button>
            <Button x:Name="ClearSessionButton" Width="120" Height="38" Margin="0,0,10,10" IsEnabled="False" Click="ClearSessionButton_OnClick">清空素材</Button>
        </WrapPanel>

        <!-- 主内容允许滚动，避免窗口较小时布局挤压/覆盖 -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,4" IsHitTestVisible="False">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="GIF 录制工具" />
                    <TextBlock Margin="0,6,0,0" Foreground="#666" TextWrapping="Wrap" IsHitTestVisible="False"
                               Text="停止录制后会自动弹出导出设置（GIF / AVI / MP4）。 感谢产品经理wublub，感谢大模型gpt-5.4/5.2" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="录制模式" />
                    <ComboBox x:Name="ModeComboBox" Grid.Column="1" SelectionChanged="ModeComboBox_OnSelectionChanged">
                        <ComboBoxItem Tag="FullScreen" IsSelected="True">全屏录制</ComboBoxItem>
                        <ComboBoxItem Tag="Region">框选区域录制</ComboBoxItem>
                        <ComboBoxItem Tag="Window">程序窗口录制</ComboBoxItem>
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="目标范围" />
                    <TextBlock x:Name="TargetSummaryTextBlock" Grid.Column="1" VerticalAlignment="Center" Text="全屏桌面" TextWrapping="Wrap" />
                    <Button x:Name="ChooseTargetButton" Grid.Column="2" Padding="14,6" Margin="10,0,0,0" Click="ChooseTargetButton_OnClick">选择目标</Button>
                </Grid>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="导入 GIF" />
                    <TextBox x:Name="ImportGifPathTextBox" Grid.Column="1" Margin="0,0,10,0" IsReadOnly="True" />
                    <Button Grid.Column="2" Padding="14,6" Click="ImportGifButton_OnClick">选择 GIF</Button>
                </Grid>

                <Border Grid.Row="8" Padding="14" Background="#F7F7F7" CornerRadius="10" IsHitTestVisible="False">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="当前素材" />
                        <TextBlock x:Name="SessionSummaryTextBlock" Margin="0,10,0,0" Text="暂无录制或导入的素材。" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="10" Padding="14" Background="#F7F7F7" CornerRadius="10" IsHitTestVisible="False">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="状态" />
                        <TextBlock x:Name="StatusTextBlock" Margin="0,8,0,0" Text="准备就绪。点击“开始录制”开始。" TextWrapping="Wrap" />
                        <TextBlock Margin="0,6,0,0" Foreground="#888" TextWrapping="Wrap" IsHitTestVisible="False"
                                   Text="如果 Alt+G 没反应：请先看“状态”里的提示（可能是快捷键注册失败或被其他软件占用）。" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
