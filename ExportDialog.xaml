<Window x:Class="GifRecorder.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导出设置"
        Width="420"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="18" FontWeight="SemiBold" Text="导出格式与品质" />

        <Border Grid.Row="2" Background="#F7F7F7" CornerRadius="10" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="导出格式" />
                <ComboBox x:Name="FormatComboBox" Grid.Row="0" Grid.Column="1" SelectionChanged="FormatComboBox_OnSelectionChanged">
                    <ComboBoxItem Tag="Gif" IsSelected="True">GIF</ComboBoxItem>
                    <ComboBoxItem Tag="Avi">AVI（MJPEG）</ComboBoxItem>
                    <ComboBoxItem Tag="Mp4">MP4</ComboBoxItem>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="预设" />
                <ComboBox x:Name="PresetComboBox" Grid.Row="2" Grid.Column="1" DisplayMemberPath="DisplayName" SelectionChanged="PresetComboBox_OnSelectionChanged" />

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="FPS" />
                <TextBox x:Name="ExportFpsTextBox" Grid.Row="4" Grid.Column="1" />

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="最大宽度" />
                <TextBox x:Name="MaxWidthTextBox" Grid.Row="6" Grid.Column="1" />

                <TextBlock x:Name="ColorCountLabel" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="颜色数" />
                <TextBox x:Name="ColorCountTextBox" Grid.Row="8" Grid.Column="1" />

                <StackPanel x:Name="GifOptionsPanel" Grid.Row="10" Grid.Column="1" Orientation="Horizontal">
                    <CheckBox x:Name="UseDitherCheckBox" Content="启用抖动" Margin="0,0,12,0" />
                    <CheckBox x:Name="OptimizeFramesCheckBox" Content="优化 GIF 帧" />
                </StackPanel>

                <StackPanel x:Name="AviOptionsPanel" Grid.Row="12" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="AVI 质量" Margin="0,0,8,0" />
                    <TextBox x:Name="AviQualityTextBox" Width="120" />
                </StackPanel>

                <TextBlock x:Name="SizeLimitLabel" Grid.Row="14" Grid.Column="0" VerticalAlignment="Top" Text="文件大小限制" />
                <StackPanel x:Name="SizeLimitPanel" Grid.Row="14" Grid.Column="1">
                    <CheckBox x:Name="EnableMaxFileSizeCheckBox" Content="限制导出文件不超过指定大小" Checked="EnableMaxFileSizeCheckBox_OnChanged" Unchecked="EnableMaxFileSizeCheckBox_OnChanged" />
                    <StackPanel x:Name="SizeLimitSettingsPanel" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox x:Name="MaxFileSizeMbTextBox" Width="120" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="MB" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,4" Text="自动调整策略" />
                        <ComboBox x:Name="AdjustmentStrategyComboBox" />
                        <TextBlock Margin="0,8,0,4" Text="仍超限时" />
                        <ComboBox x:Name="ExceededBehaviorComboBox" />
                    </StackPanel>
                </StackPanel>

                <TextBlock x:Name="SizeLimitHintTextBlock"
                           Grid.Row="18"
                           Grid.Column="1"
                           Margin="0,0,0,0"
                           Foreground="#777"
                           TextWrapping="Wrap"
                           Text="当前版本仅对 GIF 启用文件大小限制。" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="90" Height="32" Margin="0,0,8,0" Click="CancelButton_OnClick">取消</Button>
            <Button Width="110" Height="32" Click="OkButton_OnClick">选择文件并导出</Button>
        </StackPanel>
    </Grid>
</Window>
