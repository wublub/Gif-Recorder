<Window x:Class="GifRecorder.WindowPickerOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Canvas>
        <Rectangle x:Name="HighlightRect"
                   Stroke="#00FF85"
                   StrokeThickness="3"
                   Fill="#2200FF85"
                   Visibility="Collapsed"
                   IsHitTestVisible="False" />
        <Border Background="#CC1E1E1E"
                CornerRadius="6"
                Padding="12,8"
                Canvas.Left="20"
                Canvas.Top="20"
                IsHitTestVisible="False">
            <StackPanel>
                <TextBlock Foreground="White"
                           FontSize="14"
                           Text="将鼠标移动到目标窗口上，单击左键确认；按 Esc 取消。" />
                <TextBlock x:Name="WindowTitleText"
                           Margin="0,6,0,0"
                           Foreground="#9EE7FF"
                           FontSize="13"
                           Text="当前窗口：无" />
            </StackPanel>
        </Border>
    </Canvas>
</Window>
